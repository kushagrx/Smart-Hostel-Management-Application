# Backend API URL (auto-detected in most cases, this is the fallback)
# Emulator: http://10.0.2.2:5000 | Physical device: http://<your-lan-ip>:5000
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# Firebase & Google OAuth (get from team lead)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id
