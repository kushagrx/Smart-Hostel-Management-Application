PORT=5000

# Database (local PostgreSQL - for local dev only)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=smarthostel
DB_PASSWORD=your_local_db_password
DB_PORT=5432

# Supabase Remote Database (shared team DB - get from team lead)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Authentication
JWT_SECRET=get_from_team_lead
JWT_REFRESH_SECRET=get_from_team_lead

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
ANDROID_CLIENT_ID=your-android-client-id

# Twilio SMS 2FA (get from team lead)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_PHONE_NUMBER=your_twilio_phone
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Cloudinary (cloud image storage - get from team lead)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
